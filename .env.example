# OpenAI Configuration
OPENAI_API_KEY=your-api-key-here

# ChromaDB Configuration
CHROMA_DB_PATH=./chroma_db

# LLM Configuration
LLM_MODEL=gpt-4-turbo
TEMPERATURE=0.7
MAX_TOKENS=2000

# RAG Configuration
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
TOP_K_RETRIEVAL=3

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000

# Logging
LOG_LEVEL=INFO

# Distributed / silicon farm scale settings
MAX_CONCURRENT_ANALYSES=16
BATCH_SIZE=50
JOB_QUEUE_BACKEND=memory
# REDIS_URL=redis://localhost:6379   # uncomment when JOB_QUEUE_BACKEND=redis
ENABLE_CROSS_NODE_CORRELATION=true
